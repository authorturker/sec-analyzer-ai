# ─── SEC Analyzer Bot — secrets template ──────────────────
# Copy this file to .env and fill in your real values:
#     cp .env.example .env
#
# .env is git-ignored — your secrets never leave this machine.
# All four values are required; the bot refuses to start on placeholders.

# SEC requires a real "Name email@domain.com" in the User-Agent header.
EDGAR_IDENTITY=Your Name yourname@email.com

# Free key at: openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Bot token from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Your numeric chat ID from @userinfobot → /start
TELEGRAM_CHAT_ID=YOUR_CHAT_ID
