# ─── SEC Analyzer Bot — secrets template ──────────────────
# Copy this file to .env and fill in your real values:
#     cp .env.example .env
#
# .env is git-ignored — your secrets never leave this machine.
# Three values are required; the bot refuses to start without them.

# SEC requires a real "Name email@domain.com" in the User-Agent header.
EDGAR_IDENTITY=Your Name yourname@email.com

# Bot token from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Your numeric chat ID (get it from @userinfobot → /start).
# This chat becomes the permanent admin chat (chat_ids[0]).
MASTER_CHAT_ID=YOUR_CHAT_ID

# ─── Legacy / optional ─────────────────────────────────────
# These are imported once into bot_config.json on first run,
# then no longer required. You may remove them after migration.

# Free key at: openrouter.ai → Keys → Create Key
# OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Old single-chat bootstrap — superseded by MASTER_CHAT_ID.
# TELEGRAM_CHAT_ID=YOUR_CHAT_ID
